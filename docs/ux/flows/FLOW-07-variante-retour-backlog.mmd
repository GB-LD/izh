flowchart TD
    TRIGGER(["Drag tache\ndepuis la matrice"]):::trigger
    TRIGGER --> DRAG

    DRAG["SCR-10 Matrice drag actif\nTache suit le doigt/curseur\nAutres quadrants opacite reduite\nZone backlog illuminee"]:::screen

    DRAG -->|"Drop sur zone backlog"| RETURN[/"Retour au backlog\nis_in_matrix: false\nMeme quadrant conserve"/]:::loading
    DRAG -->|"Drop sur autre quadrant"| BOUNCE

    RETURN --> DONE(["Tache de retour\ndans son quadrant backlog\nEmplacement matrice libere"]):::success

    BOUNCE["SCR-10 Feedback pedagogique\nTache revient en place\nDans la matrice tu agis\nPour reclasser remets-la au backlog"]:::error
    BOUNCE --> SCR10(["Retour etat normal matrice"]):::success

    classDef screen   fill:#e8f0fe,stroke:#4285f4,color:#1a1a1a
    classDef decision fill:#fff8e1,stroke:#f9a825,color:#1a1a1a
    classDef error    fill:#fce8e6,stroke:#d93025,color:#1a1a1a
    classDef success  fill:#e8f5e9,stroke:#2e7d32,color:#1a1a1a
    classDef loading  fill:#f3e5f5,stroke:#7b1fa2,color:#1a1a1a
    classDef empty    fill:#f5f5f5,stroke:#9e9e9e,color:#1a1a1a
    classDef trigger  fill:#e0f2f1,stroke:#00695c,color:#1a1a1a
