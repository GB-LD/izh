flowchart TD
    TRIGGER(["Consultation du backlog\navec taches triees"]):::trigger
    TRIGGER --> SCR06

    SCR06["SCR-06 Backlog\n4 listes Q1 a Q4\nCompteur total N/40\nBouton activer par tache"]:::screen
    SCR06 -->|"Tap activer\nsur une tache"| DEC_FULL{"Quadrant matrice\nplein ? max 4"}:::decision

    DEC_FULL -->|"Non, moins de 4"| ACTIVATE[/"Activation\nis_in_matrix: true"/]:::loading
    DEC_FULL -->|"Oui, 4 sur 4"| ERR_QFULL

    ACTIVATE --> FEEDBACK["SCR-06 Feedback\nTache disparait avec animation\nToast: Ajoutee a ta matrice"]:::success
    FEEDBACK --> DEC_CONTINUE{"Autre tache\na activer ?"}:::decision

    DEC_CONTINUE -->|"Oui"| SCR06
    DEC_CONTINUE -->|"Nav vers matrice"| SCR10

    SCR10["SCR-10 Matrice\nGrille 2x2\nNouvelles taches en highlight\nHighlight temporaire 2-3s"]:::screen

    ERR_QFULL["Quadrant plein 4/4\nComplete ou remets-en une\nau backlog pour faire de la place"]:::error
    ERR_QFULL --> SCR06

    classDef screen   fill:#e8f0fe,stroke:#4285f4,color:#1a1a1a
    classDef decision fill:#fff8e1,stroke:#f9a825,color:#1a1a1a
    classDef error    fill:#fce8e6,stroke:#d93025,color:#1a1a1a
    classDef success  fill:#e8f5e9,stroke:#2e7d32,color:#1a1a1a
    classDef loading  fill:#f3e5f5,stroke:#7b1fa2,color:#1a1a1a
    classDef empty    fill:#f5f5f5,stroke:#9e9e9e,color:#1a1a1a
    classDef trigger  fill:#e0f2f1,stroke:#00695c,color:#1a1a1a
